# Firebase Credentials
# Get these from Firebase Console > Project Settings > Service Accounts
# Download the private key and save as serviceAccountKey.json (DO NOT COMMIT)

FIREBASE_PROJECT_ID=manhole-monitoring-e5d2b
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@manhole-monitoring-e5d2b.iam.gserviceaccount.com

# Bridge Configuration
BRIDGE_PORT=3001

# Wokwi CLI
# Get your CI token from https://wokwi.com/dashboard/ci
WOKWI_CLI_TOKEN=your_wokwi_ci_token_here
WOKWI_TIMEOUT_MS=86400000
WOKWI_SERIAL_LOG_FILE=wokwi_output.log
WOKWI_RFC2217_PORT=4000
