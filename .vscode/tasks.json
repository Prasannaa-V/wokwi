{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Wokwi: Bridge",
      "type": "shell",
      "command": "npm run bridge",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Wokwi bridge running on http://localhost:3001"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Wokwi: Watch Serial Log",
      "type": "shell",
      "command": "npm run watch:python",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Waiting for Wokwi to start"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Wokwi: GUI Serial Bridge",
      "type": "shell",
      "command": "npm run watch:gui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Connected to Wokwi RFC2217 serial server"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Wokwi: Background Simulate",
      "type": "shell",
      "command": "npm run simulate",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Connected to Wokwi Simulation API"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "simulator"
      }
    },
    {
      "label": "Dashboard: Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/../sewerly"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      }
    },
    {
      "label": "System: Start Background Stack",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Wokwi: Bridge",
        "Wokwi: Watch Serial Log",
        "Wokwi: Background Simulate",
        "Dashboard: Dev Server"
      ],
      "problemMatcher": []
    },
    {
      "label": "System: Start GUI Slider Stack",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Wokwi: Bridge",
        "Wokwi: GUI Serial Bridge",
        "Dashboard: Dev Server"
      ],
      "problemMatcher": []
    }
  ]
}
